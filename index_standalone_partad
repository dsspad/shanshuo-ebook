',
            'scene22': 'data:image/jpeg;base64,',
            'scene23': 'data:image/jpeg;base64,',
            'scene26': 'data:image/jpeg;base64,',
            'scene27': 'data:image/jpeg;base64,'
        };

        function updateScene() {
            const scene = script[currentIndex];
            
            // 更新页码
            pageNumEl.textContent = `${currentIndex + 1} / ${script.length}`;
            
            // 清除所有特殊布局类
            book.classList.remove('text-only', 'text-right', 'cross-page-text-left', 'cross-page-image-left', 'fullscreen', 'cover-fullscreen');
            
            // 重置 fullscreen 时的图片样式
            sceneImage.style.objectFit = '';
            sceneImage.style.width = '';
            sceneImage.style.height = '';
            
            // 处理无图文字场景
            if (scene.type === 'text-only') {
                book.classList.add('text-only');
                cssScene.style.display = 'none';
                sceneImage.classList.remove('active');

                // 显示上一页点击区域
                const prevBtn = document.getElementById('text-only-prev');
                if (prevBtn) prevBtn.style.display = 'block';

                // 最后一页显示返回封面按钮
                const backBtn = document.getElementById('back-to-cover');
                if (backBtn) {
                    if (currentIndex === script.length - 1) {
                        backBtn.style.display = 'block';
                    } else {
                        backBtn.style.display = 'none';
                    }
                }

                // 更新右栏文字
                typeText(scene.text);
            } else if (scene.type === 'text-right') {
                book.classList.add('text-right');
                cssScene.style.display = 'none';
                sceneImage.classList.remove('active');

                // 更新右栏文字
                typeText(scene.text);
            }
            // 处理文字在左、图片在右的跨页布局
            else if (scene.type === 'text-left') {
                book.classList.add('cross-page-text-left');
                
                // 左页显示文字
                typeText(scene.text);

                // 右页显示图片 - 使用场景索引作为key查找图片
                const sceneKey = 'scene' + (currentIndex + 1);
                if (sceneImages[sceneKey]) {
                    sceneImage.src = sceneImages[sceneKey];
                    sceneImage.classList.add('active');
                }
                cssScene.style.display = 'none';
            }
            // 处理图片在左、文字在右的跨页布局
            else if (scene.type === 'image-left') {
                book.classList.add('cross-page-image-left');

                // 左页显示图片 - 使用场景索引作为key查找图片
                const sceneKey = 'scene' + (currentIndex + 1);
                if (sceneImages[sceneKey]) {
                    sceneImage.src = sceneImages[sceneKey];
                    sceneImage.classList.add('active');
                }
                cssScene.style.display = 'none';

                // 右页显示文字
                typeText(scene.text);
            }
            // 处理全屏画面+文字悬浮
            else if (scene.type === 'fullscreen') {
                console.log('ENTERING FULLSCREEN SCENE');
                book.classList.add('fullscreen');
                cssScene.style.display = 'none';

                // 显示全屏图片
                if (scene.scene && sceneImages[scene.scene]) {
                    sceneImage.src = sceneImages[scene.scene];
                    sceneImage.classList.add('active');
                    sceneImage.style.objectFit = 'cover';
                    sceneImage.style.width = '100%';
                    sceneImage.style.height = '100%';
                }

                // 显示悬浮文字
                typeText(scene.text);

                // 整个页面点击：左侧30%上一页，右侧70%下一页
                book.onclick = function(e) {
                    console.log('Fullscreen book clicked');
                    const rect = book.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const width = rect.width;
                    console.log('Click position:', x, '/', width, '=', x/width);
                    if (x < width * 0.3) {
                        console.log('Left 30%, go prev');
                        // 左侧30%：上一页
                        if (currentIndex > 0) {
                            currentIndex--;
                            book.onclick = null;
                            updateScene();
                        }
                    } else {
                        console.log('Right 70%, go next');
                        // 右侧70%：下一页
                        if (currentIndex < script.length - 1) {
                            currentIndex++;
                            book.onclick = null;
                            updateScene();
                        }
                    }
                };
            }
            // 处理封面场景 - 图片铺满整个页面
            else if (scene.type === 'cover') {
                book.classList.add('cover-fullscreen');
                cssScene.style.display = 'none';

                // 隐藏上一页按钮
                const prevBtn = document.getElementById('text-only-prev');
                if (prevBtn) prevBtn.style.display = 'none';

                // 显示封面图片
                if (scene.scene && sceneImages[scene.scene]) {
                    console.log('Loading cover image:', sceneImages[scene.scene]);
                    sceneImage.src = sceneImages[scene.scene];
                    sceneImage.classList.add('active');
                    // 封面无文字
                    textEl.textContent = '';
                    sceneImage.onload = function() {
                        console.log('Cover image loaded successfully');
                    };
                    sceneImage.onerror = function() {
                        console.error('Cover image failed to load');
                        textEl.textContent = '封面加载失败，点击继续';
                    };
                } else {
                    console.error('No cover image found');
                    textEl.textContent = '封面未找到，点击继续';
                }

                // 封面点击下一页 - 直接绑定
                book.onclick = function(e) {
                    console.log('Cover book clicked');
                    if (currentIndex < script.length - 1) {
                        currentIndex++;
                        book.onclick = null;
                        updateScene();
                    }
                };
            } else {
                // 更新左栏场景 - 优先使用图片
                cssScene.style.display = 'none';
                
                // 清除之前的图片方向类
                sceneImage.classList.remove('vertical');
                
                // 隐藏上一页点击区域
                const prevBtn = document.getElementById('text-only-prev');
                if (prevBtn) prevBtn.style.display = 'none';
                // 隐藏返回封面按钮
                const backBtn = document.getElementById('back-to-cover');
                if (backBtn) backBtn.style.display = 'none';
                // 清除点击事件
                book.onclick = null;
                const leftPageEl = document.getElementById('left-page');
                if (leftPageEl) leftPageEl.onclick = null;
                
                if (scene.scene && sceneImages[scene.scene]) {
                    // 使用真实图片
                    sceneImage.src = sceneImages[scene.scene];
                    sceneImage.classList.add('active');
                    // scene27 使用竖版显示
                    if (scene.scene === 'scene27') {
                        sceneImage.classList.add('vertical');
                    }
                    // 检测图片尺寸，16:9横图使用全屏效果（保持比例铺平）
                    sceneImage.onload = function() {
                        const imgRatio = sceneImage.naturalWidth / sceneImage.naturalHeight;
                        // 16:9 比例约为 1.78，允许一定误差 (1.6 ~ 2.0)
                        if (imgRatio > 1.6 && imgRatio < 2.0) {
                            book.classList.add('fullscreen');
                            // 保持16:9比例，使用contain模式铺平页面
                            sceneImage.style.objectFit = 'contain';
                            sceneImage.style.width = 'auto';
                            sceneImage.style.height = 'auto';
                            sceneImage.style.maxWidth = '100%';
                            sceneImage.style.maxHeight = '100%';
                            // 16:9场景使用图片左右翻页
                            console.log('Setting book.onclick for 16:9 scene');
                            book.onclick = function(e) {
                                console.log('16:9 book clicked');
                                const rect = book.getBoundingClientRect();
                                const x = e.clientX - rect.left;
                                const width = rect.width;
                                console.log('Click at:', x, 'width:', width, 'ratio:', x/width);
                                if (x < width * 0.3) {
                                    console.log('Left 30%, go prev');
                                    if (currentIndex > 0) {
                                        currentIndex--;
                                        book.onclick = null;
                                        updateScene();
                                    }
                                } else {
                                    console.log('Right 70%, go next');
                                    if (currentIndex < script.length - 1) {
                                        currentIndex++;
                                        book.onclick = null;
                                        updateScene();
                                    }
                                }
                            };
                        }
                    };
                } else if (scene.type === 'computer') {
                    // 码表场景使用 CSS
                    sceneImage.classList.remove('active');
                    cssScene.style.display = 'block';
                    cssScene.className = 'css-scene scene-computer';
                    cssScene.innerHTML = `
                        <div class="computer-display">
                            <div class="computer-value">${scene.value}</div>
                            <div class="computer-unit">${scene.unit}</div>
                        </div>
                    `;
                } else {
                    // 其他场景使用 CSS
                    sceneImage.classList.remove('active');
                    cssScene.style.display = 'block';
                    cssScene.className = `css-scene scene-${scene.scene}`;
                    cssScene.innerHTML = '';
                }
                
                // 更新右栏文字
                typeText(scene.text);
            }
        }

        function typeText(text) {
            isTyping = false;
            textEl.innerHTML = '';

            // 按换行符分割段落
            const lines = text.split('\n');

            // 创建段落元素，直接显示
            lines.forEach((line, index) => {
                if (line.trim()) {
                    const para = document.createElement('div');
                    para.className = 'para visible';
                    para.style.marginBottom = '0.5em';
                    para.textContent = line.trim();
                    textEl.appendChild(para);
                } else if (index < lines.length - 1) {
                    // 空行添加间距
                    const br = document.createElement('div');
                    br.style.height = '1em';
                    textEl.appendChild(br);
                }
            });
        }

        // 下一页
        rightPage.addEventListener('click', (e) => {
            const scene = script[currentIndex];
            console.log('rightPage clicked, currentIndex:', currentIndex, 'type:', scene?.type);
            // fullscreen 场景（包括自动检测的16:9图片）使用图片点击翻页
            if (book.classList.contains('fullscreen')) {
                console.log('Fullscreen class detected, ignoring rightPage click');
                return;
            }
            if (isTyping) {
                // 如果正在渐显，直接显示完整文字
                const paras = textEl.querySelectorAll('.para');
                paras.forEach(p => p.classList.add('visible'));
                isTyping = false;
            } else if (currentIndex < script.length - 1) {
                currentIndex++;
                updateScene();
            }
        });

        // 上一页
        leftPage.addEventListener('click', (e) => {
            const scene = script[currentIndex];
            console.log('leftPage clicked, currentIndex:', currentIndex, 'type:', scene?.type);
            // 封面场景点击下一页
            if (scene.type === 'cover') {
                if (currentIndex < script.length - 1) {
                    currentIndex++;
                    updateScene();
                }
                return;
            }
            // fullscreen 场景（包括自动检测的16:9图片）使用图片点击翻页
            if (book.classList.contains('fullscreen')) {
                console.log('Fullscreen class detected, ignoring leftPage click');
                return;
            }
            // text-only 场景禁用 leftPage 点击（使用 text-only-prev 按钮）
            if (scene.type === 'text-only') {
                console.log('Text-only scene, ignoring leftPage click');
                return;
            }
            if (currentIndex > 0) {
                currentIndex--;
                updateScene();
            }
        });

        // text-only场景的上一页按钮
        const textOnlyPrev = document.getElementById('text-only-prev');
        if (textOnlyPrev) {
            textOnlyPrev.addEventListener('click', (e) => {
                e.stopPropagation();
                console.log('text-only-prev clicked, currentIndex:', currentIndex);
                if (currentIndex > 0) {
                    currentIndex--;
                    updateScene();
                }
            });
        }

        // 返回封面按钮
        const backToCover = document.getElementById('back-to-cover');
        if (backToCover) {
            backToCover.addEventListener('click', (e) => {
                e.stopPropagation();
                currentIndex = 0;
                updateScene();
            });
        }



        // 键盘导航
        document.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowRight' || e.key === ' ') {
                e.preventDefault();
                rightPage.click();
            } else if (e.key === 'ArrowLeft') {
                e.preventDefault();
                leftPage.click();
            }
        });

        // 初始化 - 延迟执行确保DOM完全加载
        document.addEventListener('DOMContentLoaded', function() {
            try {
                updateScene();
            } catch (e) {
                console.error('初始化错误:', e);
                document.body.innerHTML = '<div style="padding:20px;color:red;">加载出错: ' + e.message + '</div>';
            }
        });
    </script>
    <div id="version" style="position:fixed;bottom:5px;right:10px;font-size:10px;color:#999;z-index:9999;font-family:monospace;">v250404.1</div>
</body>
